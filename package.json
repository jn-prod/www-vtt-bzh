{
  "name": "www-vtt-bzh",
  "author": "Nicolas Jouanno",
  "license": "MIT",
  "version": "1.0.0",
  "engines": {
    "pnpm": "10.x",
    "node": "24.x"
  },
  "description": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jn-prod/www-vtt-bzh.git"
  },
  "bugs": {
    "url": "https://github.com/jn-prod/www-vtt-bzh/issues"
  },
  "homepage": "https://github.com/jn-prod/www-vtt-bzh#readme",
  "scripts": {
    "prepare": "husky",
    "dev": "pnpm -r dev",
    "build": "pnpm -r build && pnpm bundle-packages",
    "preview": "pnpm build && python3 -m http.server -d ./dist",
    "job": "pnpm -r job",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "bundle-packages": "rm -rf ./dist && cp -R ./www/_site/ ./dist"
  },
  "lint-staged": {
    "*.{js,ts}": "eslint --fix --ignore-path .gitignore",
    "*.{json,yaml,yml,md,mdx}": "prettier --write"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@types/node": "^22.9.0",
    "eslint": "^8.49.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "ts-node": "^10.9.2"
  }
}
