{
  "name": "www-vtt-bzh",
  "author": "Nicolas Jouanno",
  "license": "MIT",
  "version": "1.0.0",
  "packageManager": "pnpm@10.34.4",
  "engines": {
    "pnpm": "10.x",
    "node": "24.x"
  },
  "description": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jn-prod/www-vtt-bzh.git"
  },
  "bugs": {
    "url": "https://github.com/jn-prod/www-vtt-bzh/issues"
  },
  "homepage": "https://github.com/jn-prod/www-vtt-bzh#readme",
  "scripts": {
    "prepare": "husky",
    "dev": "pnpm -r dev",
    "build": "pnpm build:packages && pnpm copy:packages:calendar && pnpm build:www",
    "build:preview": "pnpm build && python3 -m http.server -d ./www/_site",
    "build:www": "pnpm --filter='www' build",
    "build:packages": "pnpm --filter='./packages/*' -r build",
    "copy:packages:calendar": "cp packages/calendar/out/events.json www/_data/events.json",
    "test": "pnpm -r test",
    "lint": "pnpm lint:eslint && pnpm lint:stylelint && pnpm lint:prettier",
    "lint:fix": "pnpm lint:eslint:fix && pnpm lint:stylelint:fix && pnpm lint:prettier:fix",
    "lint:eslint": "eslint . && stylelint 'www/assets/css/**/*.css'",
    "lint:eslint:fix": "eslint . --fix && stylelint 'www/assets/css/**/*.css' --fix",
    "lint:stylelint": "stylelint 'www/assets/css/**/*.css'",
    "lint:stylelint:fix": "stylelint 'www/assets/css/**/*.css' --fix",
    "lint:prettier": "prettier --check .",
    "lint:prettier:fix": "prettier --write .",
    "calendar:health": "node --env-file=.env scripts/calendar-health.mjs",
    "contact:migrate": "node --env-file=.env scripts/contact-migrate.mjs",
    "kit:sync": "node --env-file=.env scripts/kit-sync.mjs"
  },
  "lint-staged": {
    "*.{js,ts}": "eslint --fix",
    "*.css": "stylelint --fix",
    "*.{json,yaml,yml,md,mdx}": "prettier --write"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.2.1",
    "globals": "^16.0.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.5.0",
    "stylelint": "^16.0.0",
    "stylelint-config-standard": "^37.0.0",
    "supabase": "^2.98.2",
    "ts-node": "^10.9.2",
    "typescript-eslint": "^8.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "supabase"
    ],
    "overrides": {
      "brace-expansion@1": "^5.0.0",
      "diff@4": "^4.0.4"
    }
  }
}
